<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/home_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:text="Available devices"
        android:gravity="center"
        android:textColor="@color/cardview_dark_background"
        android:textStyle="bold"
        android:paddingStart="16dp"
        android:paddingTop="15dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/settings_button"
        android:layout_width="110dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="10dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:contentDescription="Open Settings"
        android:text="Settings" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/add_device"
        android:layout_width="130dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/settings_button"
        android:layout_marginEnd="10dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:contentDescription="Add new device"
        android:text="New device"
        android:textAlignment="center"
        tools:listItem="@layout/popup_menu"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/meeting_button"
        android:layout_width="110dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/add_device"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:layout_marginEnd="10dp"
        android:contentDescription="Meeting"
        android:text="Meeting"/>

    <SearchView
        android:id="@+id/search_devices"
        android:layout_width="300dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/home_text"
        app:layout_constraintEnd_toStartOf="@id/add_device"
        android:gravity="center"
        android:queryHint="Search devices" />

    <GridView
        android:id="@+id/grid_view"
        android:layout_width="wrap_content"
        android:layout_height="490dp"
        android:numColumns="4"
        android:gravity="center"
        android:layout_marginTop="50dp"
        android:verticalSpacing="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:listitem="@layout/card_item" />



</androidx.constraintlayout.widget.ConstraintLayout>

